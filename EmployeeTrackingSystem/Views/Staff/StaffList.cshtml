    <div class="modal-dialog" style="max-width:400px;">
        <div class="modal-content">
            <!-- Header -->
            <div class="modal-header">
                <div class="modal-title">スタッフ追加</div>
            </div> <!-- Body -->
            <div class="modal-body">
                <form id="addForm">
                    @Html.AntiForgeryToken()
                    <div class="form-container">

                        <div class="form-row">
                            <label>スタッフCD</label>
                            <input type="text" style="width:80px;" name="StaffCD"  id="StaffCD" data-ajax-check="/Staff/CheckStaffCD" />
                            <span class="text-danger" id="errStaffCD"></span>

                        </div>
                        <div class="form-row">
                            <label>スタッフ名</label>
                            <input type="text" name="StaffName"  />
                            <span class="text-danger" id="errStaffName"></span>
                        </div>

                        <div class="form-row">
                            <label>部門CD</label>
                            @Html.DropDownList("DepartmentCD", ViewBag.Departments as SelectList)
                            @*,
                                new { @class = "form-control" }))*@
                            <span class="text-danger" id="errDepartmentCD"></span>
                        </div>

                        <div class="form-row">
                            <label>位置</label>
                            <input type="text" name="Position" />
                            <span class="text-danger" id="errPosition"></span>
                        </div>

                        <div class="form-row">
                            <label>メール</label>
                            <input type="text" name="Email" data-required="true" data-validate="email" />
                            <span class="text-danger" id="errEmail"></span>
                        </div>

                        <div class="form-row">
                            <label>電話番号</label>
                            <input type="text" name="PhoneNo" />
                            <span class="text-danger" id="errPhoneNo"></span>
                        </div>

                        <div class="form-row">
                            <label>入会日</label>
                            <input type="text" name="JoinedDate" id="JoinedDateAdd" placeholder="yyyy/MM/dd" />
                        </div>

                        <div class="form-row">
                            <label>従業員の種類</label>
                            <select name="EmployeeType">
                                <option>Full Time</option>
                                <option>Part Time</option>
                            </select>
                        </div>
                        <div class="form-row">
                            <label>登録済み</label>
                            <div class="radio-group">
                                <label>  <input type="radio" name="Enroll" value="true" checked>Active</label>
                                <label>  <input type="radio" name="Enroll" value="false">InActive</label>
                            </div>
                        </div>
                        <div class="form-row">
                            <label style=" height: 55px !important;">リマーク</label>
                            <textarea name="Remark" rows="2" style=" height: 60px !important;"></textarea>
                            <span class="text-danger" id="errRemark"></span>
                        </div>
