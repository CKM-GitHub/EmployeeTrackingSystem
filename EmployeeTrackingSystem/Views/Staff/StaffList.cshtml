                        </div>
                        <div class="form-actions">
                            <button type="button" class="btn-cancel" data-dismiss="modal">取消</button>
                            <button type="submit" class="btn-submit">登録</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<style>

