        //    return new TextEncoder().encode(str).length;
        //}

        //function checkLength(el, maxBytes, errorId) {
        //    const bytes = getUtf8ByteLength(el.value);
        //    const msg = document.getElementById(errorId);

        //    if (bytes > maxBytes) {
        //        msg.textContent = "最大 " + maxBytes + " バイトを超えています";
        //        el.classList.add("input-error");
        //        new TextEncoder().encode(el.value).slice(0, maxBytes)
        //    } else {
        //        msg.textContent = "";
        //        el.classList.remove("input-error");
        //    }
        //}

    </script>
}






