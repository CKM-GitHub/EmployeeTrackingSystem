@model List<EmployeeTrackingSystem.Models.staffViewModel.StaffViewModel>

@{
    ViewBag.Title = "Staff List";
}
<div class="container mt-2">

    @section Buttons {
        <div class="d-flex mb-2">
            <button type="button" id="btnSearch" class="btn btn-warning btn-fixed me-2">
                変更
            </button>
            <button type="button" class="btn btn-primary btn-fixed" data-toggle="modal" data-target="#addModal">
                追加
            </button>
        </div>
    }

    <!-- TABLE AREA -->
    <div class="table-warpper table-v-scroll table-responsive">

        <table class="table table-striped table-hover" id="tableStaff">
            <thead class="table-dark">
                <tr class="table-header">
                    <th>スタッフCD</th>
                    <th>スタッフ名</th>
                    <th>部門名</th>
                    <th style="text-align:center">入会日</th>
                    <th style="text-align:center">席番号</th>
                    <th style="text-align:center">
                        Next <br />
                        席番号
                    </th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-right"> @item.StaffCD</td>
                            <td class="text-right">@item.StaffName</td>
                            <td class="text-right">
                                @item.DepartmentName
                                <input type="hidden" class="deptCD" value="@item.DepartmentCD" />
                            </td>
                            <td class="text-center">
                                @(item.JoinedDate.HasValue? item.JoinedDate.Value.ToString("yyyy/MM/dd")
    : "")
                            </td>
                            <td class="text-center">@item.SeatNo</td>
                            <td class="text-center">
                                <input type="text" class="newSeat"
                                       oninput="this.value = this.value.replace(/\D/g,'')"
                                       onpaste="event.preventDefault();"
                                       style="text-align: center;" />
                            </td>
                            <td>
                                <button class="btn btn-primary" onclick="openEditPopup(this)">
                                    変更
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-danger">
                            No data found
                        </td>
                    </tr>
                }
            </tbody>
        </table>


    </div>

    <div>
        <button type="button"
                class="btn btn-primary"
                style="display:block; margin-left:auto; margin-right:23px;margin-top:8px; width:100px;"
                onclick="updateSeat()">
            席を変わる
        </button>
    </div>

</div>
<!--btnSearch-->
@section scripts {
    <script>
        $(document).on("click", "#btnSearch", function () {

            var dept = $("#department").val();
            var staff = $("#staff").val();
            $.ajax({
                url: '/Staff/StaffList',
                type: 'GET',
                data: {
                    department: dept,
                    staff: staff
                },
                success: function (result) {
                    $("#tableStaff").html(
                        $(result).find("#tableStaff").html()
                    );
                },
                error: function () {
                    alert("Error loading data");
                }
            });
        });
    </script>

    <!--addForm-->
    <script id="ajaxsave02">
        $("#addForm").on("submit", function (e) {
            e.preventDefault();
            $(".text-danger").text("");// clear old errors
        var enrollValue = $("input[name='Enroll']:checked").val();
        $.ajax({
            url: '@Url.Action("Create", "Staff")',
            type: 'POST',
            data: $(this).serialize(),

            success: function (res) {

                if (res.success) {
                    alert("登録成功しました");
                    $("#addModal").modal('hide');
                    location.reload();
                }
                else {
                    if (res.errors) {
                        res.errors.forEach(function (err) {
                            var fieldName = err.field.replace("model.", "");
                            $('#addForm #err' + fieldName).text(err.message);
                        });
                    }

                }
            },

            error: function () {
                alert("エラーが発生しました");
            }
        });
        });


        $('#addModal .btn-cancel').on('click', function () {
            var form = $('#addForm')[0];
            form.reset();                // reset all form fields
            $('.text-danger').text('');        // clear error messages
            $('#addForm input, #addForm select, #addForm textarea').removeClass('is-invalid');
        });

    </script>

    <!--editForm-->
    <script>
        $(document).ready(function () {

            $('#editForm').submit(function (e) {
                e.preventDefault(); //
                $(".text-danger").text("");
                $.ajax({
                    url: '/Staff/Update',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            alert(res.message);
                            $('#editModal').modal('hide');
                            location.reload();

                        } else {
                            if (res.errors) {
                                res.errors.forEach(function (err) {
                                    $("#err" + err.field).text(err.message);
                                });
                            }

                        }
                    },
                    error: function () {
                        alert("エラーが発生しました");
                    }
                });

            });

        });


        $('#editModal .btn-cancel').on('click', function () {
            var form = $('#editForm')[0];
            form.reset();                // reset all form fields
            $('.text-danger').text('');        // clear error messages
            $('#editForm input, #editForm select, #editForm textarea').removeClass('is-invalid');
        });
    </script>
}

<!--UpdateSeat-->
<script>

    function updateSeat() {
        let rows = document.querySelectorAll("#tableStaff tbody tr");
        let dataList = [];
        let seatMap = {}; // {DepartmentCD: {SeatNo: StaffCD } }
        let swaps = [];   

        // Step 1: Build current seat map and collect inputs
        rows.forEach(row => {
            let seatInput = row.querySelector(".newSeat");
            if (seatInput && seatInput.value !== "") {
                let StaffCD = row.cells[0].innerText.trim();
                let SeatNo = seatInput.value.trim();
                let DepartmentCD = row.querySelector(".deptCD").value;

                // Initialize department in seatMap
                if (!seatMap[DepartmentCD]) seatMap[DepartmentCD] = {};

                // Check for conflicts
                if (seatMap[DepartmentCD][SeatNo]) {
                    // Already assigned, prepare for potential swap
                    swaps.push({
                        StaffCD1: StaffCD,
                        StaffCD2: seatMap[DepartmentCD][SeatNo],
                        Seat1: SeatNo,
                        Seat2: rows[rowIndexByStaff(DepartmentCD, seatMap[DepartmentCD][SeatNo], rows)].cells[4].innerText.trim()
                    });
                }

                seatMap[DepartmentCD][SeatNo] = StaffCD;

                dataList.push({
                    StaffCD: StaffCD,
                    SeatNo: SeatNo,
                    DepartmentCD: DepartmentCD
                });
            }
        });

        // Step 2: Detect duplicates outside swaps
        let duplicateFound = false;
        Object.keys(seatMap).forEach(dept => {
            let seats = seatMap[dept];
            let seen = {};
            for (let seat in seats) {
                if (seen[seat]) {
                    duplicateFound = true;
                    alert(`Seat ${seat} in Department ${dept} is duplicated. Correct before submitting.`);
                    return;
                }
                seen[seat] = true;
            }
        });
        if (duplicateFound) return;

        // Step 3: Perform swaps in table for visual feedback
        swaps.forEach(s => {
            let row1 = getRowByStaff(s.StaffCD1, rows);
            let row2 = getRowByStaff(s.StaffCD2, rows);

            let temp = row1.cells[4].innerText;
            row1.cells[4].innerText = row2.cells[4].innerText;
            row2.cells[4].innerText = temp;

            // Update the newSeat input values as well
            row1.querySelector(".newSeat").value = row1.cells[4].innerText;
            row2.querySelector(".newSeat").value = row2.cells[4].innerText;
        });

        
        if (dataList.length === 0) {
            alert("No seat entered");
            return;
        }

        $.ajax({
            url: '/Staff/UpdateSeat',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(dataList),
            success: function (res) {
                alert(res);
                location.reload(); // refresh table
            },
            error: function (err) {
                alert("Error: " + err.responseText);
            }
        });

        //  get row by StaffCD
        function getRowByStaff(staffCD, allRows) {
            for (let r of allRows) {
                if (r.cells[0].innerText.trim() === staffCD) return r;
            }
            return null;
        }

        // : get row index by StaffCD in a department
        function rowIndexByStaff(deptCD, staffCD, allRows) {
            for (let i = 0; i < allRows.length; i++) {
                let row = allRows[i];
                if (row.querySelector(".deptCD").value === deptCD && row.cells[0].innerText.trim() === staffCD) return i;
            }
            return -1;
        }
    }

</script>
<!--Update-->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog" style="max-width:500px;">
        <div class="modal-content">
            <!-- Header -->
            <div class="modal-header">
                <div class="modal-title">スタッフ修正</div>
            </div> <!-- Body -->
            <div class="modal-body">
                <form id="editForm">
                    @Html.AntiForgeryToken()
                    <div class="form-container">

                        <div class="form-row">
                            <label>スタッフCD</label>
                            <input type="text" id="StaffCD" name="StaffCD" readonly style="background-color:lightgray" required />
                            <span class="text-danger" id="errStaffCD"></span>
                        </div>

                        <div class="form-row">
                            <label>スタッフ名</label>
                            <input type="text" id="StaffName" name="StaffName" />
                            <span class="text-danger" id="errStaffName"></span>
                        </div>

                        <div class="form-row">
                            <label>部門CD</label>
                            @Html.DropDownList("DepartmentCD", ViewBag.Departments as SelectList)

                            <span class="text-danger" id="errDepartmentCD"></span>
                        </div>

                        <div class="form-row">
                            <label>位置</label>
                            <input type="text" name="Position" />
                            <span class="text-danger" id="errPosition"></span>
                        </div>

                        <div class="form-row">
                            <label>メール</label>
                            <input type="text" name="Email" />
                            <span class="text-danger" id="errEmail"></span>
                        </div>

                        <div class="form-row">
                            <label>電話番号</label>
                            <input type="text" name="PhoneNo" />
                            <span class="text-danger" id="errPhoneNo"></span>
                        </div>

                        <div class="form-row">
                            <label>入会日</label>
                            <input type="date" name="JoinedDate" />
                        </div>

                        <div class="form-row">
                            <label>従業員の種類</label>
                            <select name="EmployeeType">
                                <option>Full Time</option>
                                <option>Part Time</option>
                            </select>
                        </div>

                        <div class="form-row">
                            <label>登録済み</label>
                            <div class="radio-group">
                                <label>  <input type="radio" name="Enroll" value="true" checked /> Active</label>
                                <label><input type="radio" name="Enroll" value="false" /> InActive</label>
                            </div>
                        </div>

                        <div class="form-row">
                            <label style="height: 55px !important;">リマーク</label>
                            <textarea name="Remark" rows="2" style=" height: 60px !important;"></textarea>
                        </div>

                        <div class="form-row">
                            <label>席番号</label>
                            <input type="number" id="SeatNo" name="SeatNo" style="width:50px;background-color:lightgray" readonly />
                        </div>

                        <!-- Buttons -->
                        <div class="form-actions">
                            <button type="button" class="btn-cancel" data-dismiss="modal">取消</button>
                            <button type="submit" class="btn-submit">修正</button>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
    function openEditPopup(btn) {

        let row = btn.closest("tr");

        document.getElementById("StaffCD").value = row.cells[0].innerText;
        document.getElementById("StaffName").value = row.cells[1].innerText;
        document.getElementById("SeatNo").value = row.cells[4].innerText;

        $('#editModal').modal('show');
    }

</script>
