<script id="ajaxsave02">
    $("#addForm").on("submit", function (e) {
        e.preventDefault(); //

        $(".error").text(""); // clear old errors
        var enrollValue = $("input[name='Enroll']:checked").val();


        $.ajax({
            url: '@Url.Action("Create", "Staff")',
            type: 'POST',
            data: $(this).serialize(),

            success: function (res) {

                if (res.success) {
                    alert("登録成功しました");

                    // close modal
                    $("#addModal").modal('hide');

                    // reload page (or refresh table)
                    location.reload();
                }
                else {
                    //  show field errors
                    if (res.field === "StaffCD") {
                        $("#errStaffCD").text(res.message);
                    }
                    else if (res.field === "StaffName") {
                        $("#errStaffName").text(res.message);
                    }
                    else if (res.field === "DepartmentCD") {
                        $("#errDepartmentCD").text(res.message);
                    }
                    else if (res.field === "Email") {
                        $("#errEmail").text(res.message);
                    }
                    else {
                        alert(res.message);
                    }
                }
            },

            error: function () {
                alert("エラーが発生しました");
            }
        });
    });
</script>
