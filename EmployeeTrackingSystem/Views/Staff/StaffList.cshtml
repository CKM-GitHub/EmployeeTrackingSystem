
@using EmployeeTrackingSystem.Models
@model List<staffViewModel>

@{ ViewBag.Title = "Staff List"; }
<div class="container mt-2">

    @section Buttons {
        <div class="d-flex mb-2">
            <button type="button" id="btnSearch" class="btn_search btn">
                変更
            </button>
            <button type="button" class="btn_Blue btn btn-primary" data-toggle="modal" data-target="#addModal">
                追加
            </button>
        </div>
    }

    <!-- TABLE AREA -->
    <div class="table-wrapper table-v-scroll table-responsive">
        <table id="tableStaff" class="table table-striped table-hover">

            <thead class="table-dark">
                <tr class="table-header">
                    <th>スタッフCD</th>
                    <th>スタッフ名</th>
                    <th>部門名</th>
                    <th class="th_center">入会日</th>
                    <th class="th_center">席番号</th>
                    <th class="th_center">
                        Next <br />
                        席番号
                    </th>
                    <th class="th_center">Action</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-left"> @item.StaffCD</td>
                            <td class="text-left">@item.StaffName</td>
                            <td class="text-left">
                                @item.DepartmentName
                                <input type="hidden" class="deptCD" value="@item.DepartmentCD" />
                                <input type="hidden" class="position" value="@item.Position" />
                                <input type="hidden" class="email" value="@item.Email" />
                                <input type="hidden" class="phoneNo" value="@item.PhoneNo" />
                                <input type="hidden" class="remark" value="@item.Remark" />
                                <input type="hidden" class="employeetype" value="@item.EmployeeType" />
                                <input type="hidden" class="enroll" value="@item.Enroll.ToString().ToLower()" />
                            </td>
                            <td class="text-center">
                                @(item.JoinedDate.HasValue ? item.JoinedDate.Value.ToString("yyyy/MM/dd") : "")
                            </td>
                            <td class="text-center">@item.SeatNo</td>
                            <td class="text-center">
                                <input type="text" class="newSeat" maxlength="2"
                                       oncompositionstart="this.c=1"
                                       oncompositionend="this.c=0;this.oninput()"
                                       oninput="
                                           if(this.c) return;
                                           this.value = this.value.replace(/\D/g,'').replace(/^0+/, '').slice(0,2);" />

                            </td>

                            <td>
                                <button class="btn btn-primary">
                                    変更
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {

                }
            </tbody>
        </table>
    </div>

    <div class="btn-wrapper">
        <button type="button" id="btnUpdateSeat"
                class="btn_Blue btn btn-primary">
            席を変わる
        </button>
    </div>

</div>

<!--Update-->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog" style="max-width:400px;">
        <div class="modal-content">
            <!-- Header -->
            <div class="modal-header">
                <div class="modal-title">スタッフ修正</div>
            </div> <!-- Body -->
            <div class="modal-body">
                <form id="editForm">
                    @Html.AntiForgeryToken()
                    <div class="form-container">

                        <div class="form-row">
                            <label>スタッフCD</label>
                            <input type="text" id="StaffCD" name="StaffCD" class="staff-code" readonly />
                            <span class="text-danger" id="errStaffCD"></span>
                        </div>

                        <div class="form-row">
                            <label>スタッフ名</label>
                            <input type="text" id="StaffName" name="StaffName" />
                            <span class="text-danger" id="errStaffName"></span>
                        </div>

                        <div class="form-row">
                            <label>部門CD</label>
                            @Html.DropDownList("DepartmentCD", ViewBag.Departments as SelectList, new { @class = "DepartmentCD" })
                            @*//form-control*@

                            <span class="text-danger" id="errDepartmentCD"></span>
                        </div>

                        <div class="form-row">
                            <label>位置</label>
                            <input type="text" name="Position" id="Position" />
                            <span class="text-danger" id="errPosition"></span>
                        </div>

                        <div class="form-row">
                            <label>メール</label>
                            <input type="text" name="Email" id="Email" />
                            <span class="text-danger" id="errEmail"></span>
                        </div>

                        <div class="form-row">
                            <label>電話番号</label>
                            <input type="text" name="PhoneNo" id="PhoneNo" />
                            <span class="text-danger" id="errPhoneNo"></span>
                        </div>

                        <div class="form-row">
                            <label>入会日</label>
                            <div class="date-wrapper">
                                <input type="text" id="JoinedDate" name="JoinedDate" placeholder="yyyy/MM/dd" />
                            </div>
                        </div>

                        <div class="form-row">
                            <label>従業員の種類</label>
                            <select name="EmployeeType" class="EmployeeType" id="EmployeeType">
                                <option>Full Time</option>
                                <option>Part Time</option>
                            </select>
                        </div>

                        <div class="form-row">
                            <label>登録済み</label>
                            <div class="radio-group">
                                <label>  <input type="radio" name="Enroll" value="true" checked /> Active</label>
                                <label><input type="radio" name="Enroll" value="false" /> InActive</label>
                            </div>
                        </div>

                        <div class="form-row">
                            <label class="label-remark">リマーク</label>
                            <textarea name="Remark" id="Remark" class="textarea-remark" rows="2"></textarea>
                            <span class="text-danger" id="errRemark"></span>
                        </div>

                        <div class="form-row">
                            <label>席番号</label>
                            <input type="text" id="SeatNo" name="SeatNo" class="short-input" maxlength="2"
                                   oncompositionstart="this.c=1"
                                   oncompositionend="this.c=0;this.oninput()"
                                   oninput="
                                           if(this.c) return;
                                           this.value = this.value.replace(/\D/g,'').replace(/^0+/, '').slice(0,2);
                                         " />
                        </div>

                        <!-- Buttons -->
                        <div class="form-actions">
                            <button type="button" class="btn-cancel" data-dismiss="modal">取消</button>
                            <button type="submit" class="btn-submit">修正</button>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ADD-->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog" style="max-width:400px;">
        <div class="modal-content">
            <!-- Header -->
            <div class="modal-header">
                <div class="modal-title">スタッフ追加</div>
            </div> <!-- Body -->
            <div class="modal-body">
                <form id="addForm">
                    @Html.AntiForgeryToken()
                    <div class="form-container">

                        <div class="form-row">
                            <label>スタッフCD</label>
                            <input type="text" name="StaffCD" id="StaffCD" class="staff-new-code" data-ajax-check="/Staff/CheckStaffCD" tabindex="1" />
                            <span class="text-danger" id="errStaffCD"></span>
                        </div>
                        <div class="form-row">
                            <label>スタッフ名</label>
                            <input type="text" name="StaffName" />
                            <span class="text-danger" id="errStaffName"></span>
                        </div>

                        <div class="form-row">
                            <label>部門CD</label>
                            @Html.DropDownList("DepartmentCD", ViewBag.Departments as SelectList)
                            @*,
                                new { @class = "form-control" }))*@
                            <span class="text-danger" id="errDepartmentCD"></span>
                        </div>

                        <div class="form-row">
                            <label>位置</label>
                            <input type="text" name="Position" />
                            <span class="text-danger" id="errPosition"></span>
                        </div>

                        <div class="form-row">
                            <label>メール</label>
                            <input type="text" name="Email" data-required="true" data-validate="email" />
                            <span class="text-danger" id="errEmail"></span>
                        </div>

                        <div class="form-row">
                            <label>電話番号</label>
                            <input type="text" name="PhoneNo" />
                            <span class="text-danger" id="errPhoneNo"></span>
                        </div>

                        <div class="form-row">
                            <label>入会日</label>
                            <div class="date-wrapper">
                                <input type="text" name="JoinedDate" id="JoinedDateAdd" placeholder="yyyy/MM/dd" />
                            </div>
                        </div>
                        <div class="form-row">
                            <label>従業員の種類</label>
                            <select name="EmployeeType">
                                <option>Full Time</option>
                                <option>Part Time</option>
                            </select>
                        </div>
                        <div class="form-row">
                            <label>登録済み</label>
                            <div class="radio-group">
                                <label>  <input type="radio" name="Enroll" value="true" checked>Active</label>
                                <label>  <input type="radio" name="Enroll" value="false">InActive</label>
                            </div>
                        </div>
                        <div class="form-row">
                            <label class="label-remark">リマーク</label>
                            <textarea name="Remark" class="textarea-remark" rows="2"></textarea>
                            <span class="text-danger" id="errRemark"></span>
                        </div>
                        <div class="form-row">
                            <label>席番号</label>
                            <input type="text" name="SeatNo" class="short-input"
                                   maxlength="2"
                                   oncompositionstart="this.c=1"
                                   oncompositionend="this.c=0;this.oninput()"
                                   oninput="
                                           if(this.c) return;
                                           this.value = this.value.replace(/\D/g,'').replace(/^0+/, '').slice(0,2);" />

                            <span class="text-danger" id="errSeatNo"></span>
                        </div>
                        <div class="form-actions">
                            <button type="button" class="btn-cancel" data-dismiss="modal">取消</button>
                            <button type="submit" class="btn-submit">登録</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section scripts {
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/StaffList.css" />
    <script>
    $(document).ready(function () {
    $('#department').select2();
    $('#staff').select2();
    initDatePickers();

    $('#addForm [name="DepartmentCD"]').on('change', toggleSeatNo);
    $('#addModal').on('shown.bs.modal', toggleSeatNo);

    // =====================
    // Add Form Enter key validation
    // =====================
        $('#addModal').on('shown.bs.modal', function () {
            $("#addForm [name='StaffCD']").focus();
        });

        $('#editModal').on('shown.bs.modal', function () {
            $("#editForm [name='StaffName']").focus();
        });

    var requiredFields = ["StaffCD", "StaffName", "DepartmentCD"];

    $('#addForm input, #addForm select, #addForm textarea').on('keypress', function (e) {
        if (e.which === 13) { // Enter key
            e.preventDefault();
            $("#addForm .input-error").removeClass("input-error");
            var $this = $(this);
            var fieldName = $this.attr('name');

            // =====  Check required fields =====
            requiredFields.forEach(function (name) {
                var value = $("#addForm [name='" + name + "']").val().trim();
                if (value === "") {
                    $("#addForm #err" + name).text("*");

                } else {
                    $("#addForm #err" + name).text(""); // clear if filled
                }
            });
            // ===== StaffCD duplicate check =====

            if (fieldName === "StaffCD") {
                var staffCD = $this.val().trim();
                if (staffCD !== "") {
                    $.ajax({
                        url: '/Staff/CheckStaffCD',
                        type: 'GET',
                        data: { staffCD: staffCD },
                        success: function (res) {
                            if (res.errorType === "inactive") {
                                alert(res.message);
                                $this.addClass("input-error");
                                return;
                            }

                            //  duplicate case
                            if (res.exists) {
                                $this.addClass("input-error");
                            }

                            //  valid case
                            else {
                                $this.removeClass("input-error");
                                moveToNextFieldAdd($this);
                            }
                        },
                        error: function () {
                            console.error("Error checking StaffCD");
                        }
                    });
                    return; // stop here, next field move handled in AJAX
                } else {
                    return; // stop, empty StaffCD already shows error
                }
            }
            // =====  Move to next field if no error =====
            moveToNextFieldAdd($this);
        }
    });

    // ===== Clear error when typing =====
    $('#addForm input, #addForm select, #addForm textarea').on('input', function () {
        if ($(this).val().trim() !== "") {
            $(this).removeClass("input-error");
        }
    });

    // =====================
    // ADD FORM
    // =====================

    $(document).on("submit", "#addForm", function (e) {
        e.preventDefault();
        //clear previous errors
        $("#addForm .input-error").removeClass("input-error");
        $("#addForm .text-danger").text("");
        $.ajax({
            url: '@Url.Action("Create", "Staff")',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    alert("登録成功しました");
                    $("#addModal").modal('hide');
                    location.reload();
                } else if (res.errorType === "inactive") {
                   
                    alert(res.message);
                    var $field = $("#addForm [name='StaffCD']");
                    $field.addClass("input-error");
                    $field.focus();
                }
                else if (res.errors) {
                    res.errors.forEach(function (err) {
                        var fieldName = err.field.replace("model.", "");
                        var $field = $("#addForm [name='" + fieldName + "']");
                        $field.addClass("input-error");
                    });
                    //  focus first error field
                    var firstError = $("#addForm .input-error").first();
                    if (firstError.length) {
                        firstError.focus();
                    }
                }
            },
            error: function () {
                console.error("エラーが発生しました");
            }
        });
        });

    // Add modal cancel
    $(document).on("click", "#addModal .btn-cancel", function () {
        $('#addForm')[0].reset();
        $('.text-danger').text('');
        $("#addForm .input-error").removeClass("input-error");
    });
    // =====================
    // SEARCH
    // =====================
    $(document).on("click", "#btnSearch", function () {
        var dept = $("#department").val();
        var staff = $("#staff").val();

        $.ajax({
            url: '/Staff/StaffList',
            type: 'GET',
            data: { department: dept, staff: staff },
            success: function (result) {
                $("#tableStaff tbody").html($(result).find("#tableStaff tbody").html());
            },
            error: function () {
               // alert("Error loading data");
            }
        });
    });
    // =====================
    // OPEN EDIT MODAL
    // =====================
    $(document).on("click", "#tableStaff tbody .btn-primary", function () {

        let row = $(this).closest("tr");

        $("#StaffCD").val(row.find("td").eq(0).text().trim());
        $("#StaffName").val(row.find("td").eq(1).text().trim());
        $("#DepartmentCD").val(row.find(".deptCD").val());
        $("#Position").val(row.find(".position").val());
        $("#Email").val(row.find(".email").val());
        $("#PhoneNo").val(row.find(".phoneNo").val());
        $("#Remark").val(row.find(".remark").val());
        $("#EmployeeType").val(row.find(".employeetype").val());

        let joinedText = row.find("td").eq(3).text().trim();
        $("#JoinedDate").val(joinedText ? joinedText.replace(/\//g, "/") : "");


        $("#SeatNo").val(row.find("td").eq(4).text().trim());

        let enrollVal = row.find(".enroll").val();
        $("#editModal input[name='Enroll'][value='" + enrollVal + "']").prop("checked", true);

        $('#editModal').modal('show');

        setTimeout(() => $("#StaffName").focus(), 300);
    });
    // =====================
    // EDIT FORM
    // =====================

    $('#editForm input, #editForm select, #editForm textarea').on('keypress', function (e) {
        if (e.which === 13) { // Enter key
            e.preventDefault();
            var $this = $(this);

            moveToNextFieldEdit($this);
        }
    });
    $(document).on("submit", "#editForm", function (e) {
        e.preventDefault();
        $("#editForm .input-error").removeClass("input-error");
        $(".text-danger").text("");

        $.ajax({
            url: '/Staff/Update',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {

                    alert("登録成功しました");
                    $("#editModal").modal('hide');
                    location.reload();

                }
                else if (res.errors) {

                    res.errors.forEach(function (err) {
                        var fieldName = err.field.replace("model.", "");
                        var $field = $("#editForm [name='" + fieldName + "']");
                        $field.addClass("input-error");
                    });
                    var firstError = $("#editForm .input-error").first();
                    if (firstError.length) {
                        firstError.focus();
                    }
                }
            },
            error: function () {
                //alert("エラーが発生しました");
            }
        });
        });


    // Edit modal cancel
    $(document).on("click", "#editModal .btn-cancel", function () {
        $('#editForm')[0].reset();
        $('.text-danger').text('');
        $("#editForm .input-error").removeClass("input-error");
    });

    // =====================
    // UPDATE SEAT
    // =====================
    $(document).on("click", "#btnUpdateSeat", function () {

        let rows = $("#tableStaff tbody tr");
        let dataList = [];
        let seatMap = {};
        let duplicateFound = false;

        rows.each(function () {
            let row = $(this);
            let seatInput = row.find(".newSeat");

            if (seatInput.val() !== "") {

                let StaffCD = row.find("td").eq(0).text().trim();
                let SeatNo = seatInput.val().trim();
                let DepartmentCD = row.find(".deptCD").val();
                let DeptName = row.find("td").eq(2).text().trim();

                if (!seatMap[DepartmentCD]) seatMap[DepartmentCD] = {};

                if (seatMap[DepartmentCD][SeatNo]) {
                    duplicateFound = true;
                    alert(`Seat ${SeatNo} in  ${DeptName} Department is duplicated.`);
                    return false;
                }

                seatMap[DepartmentCD][SeatNo] = StaffCD;

                dataList.push({
                    StaffCD: StaffCD,
                    SeatNo: SeatNo,
                    DepartmentCD: DepartmentCD
                });
            }
        });

        if (duplicateFound || dataList.length === 0) {
            if (dataList.length === 0) alert("No seat entered");
            return;
        }

        $.ajax({
            url: '/Staff/UpdateSeat',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(dataList),
            success: function (res) {
                alert(res);
                location.reload();
            },
            error: function (err) {
               // alert("Error: " + err.responseText);
            }
        });

    });

    $("#tableStaff").on("keydown", ".newSeat", function (e) { // 20260416 ttw

            if (e.key === "Enter") {
                e.preventDefault();

                var inputs = $("#tableStaff .newSeat");
                var index = inputs.index(this);

                if (index + 1 < inputs.length) {
                    inputs.eq(index + 1).focus();
                }
            }
        });

    });


    // =====================
    // DATEPICKER: Add & Edit
    // =====================
        function initDatePickers() {
            $("#JoinedDate, #JoinedDateAdd").datepicker({
                dateFormat: "yy/mm/dd"
            });

            // prevent invalid characters
            $("#JoinedDate, #JoinedDateAdd").on("input", function () {
                this.value = this.value.replace(/[^0-9\/]/g, '');
            });

            // default today for Add
            if (!$("#JoinedDateAdd").val()) {
                $("#JoinedDateAdd").val($.datepicker.formatDate('yy/mm/dd', new Date()));
            }
        //$("#JoinedDate,#JoinedDateAdd").datepicker({
        //    dateFormat: "yy/mm/dd",
        //    showOn: "button",
        //    buttonText: "📅"
        //});
        ////$("#JoinedDateAdd").datepicker({
        ////    dateFormat: "yy/mm/dd"
        ////});

        //// Auto open on focus
        //////$(document).on("focus", "#JoinedDate, #JoinedDateAdd", function () {
        //////    $(this).datepicker("show");
        //////});

        //// Optional: default today date in Add modal
        //if (!$("#JoinedDateAdd").val()) {
        //    $("#JoinedDateAdd").val($.datepicker.formatDate('yy/mm/dd', new Date()));
        //}

        //$("#JoinedDate, #JoinedDateAdd").on("input", function () {
        //    this.value = this.value.replace(/[^0-9\/]/g, '');
        //});
    }

    function toggleSeatNo() {
        var dept = $('#addForm [name="DepartmentCD"]').val();
        var disable = dept.startsWith('S'); // 20260416 ttw
        //  var disable = ["S01", "S02", "S03"].includes(dept);

        $('#addForm [name="SeatNo"]')
            .val(disable ? "" : $('#addForm [name="SeatNo"]').val())
            .prop("disabled", disable);

        $("#JoinedDateAdd").val($.datepicker.formatDate('yy/mm/dd', new Date())); // 20260416 ttw
    }

    // ===== Helper to move focus =====
    function moveToNextFieldEdit($current) {
        var $fields = $('#editForm').find('input, select, textarea').filter(':visible');
        var index = $fields.index($current);
        if (index + 1 < $fields.length) {
            $fields.eq(index + 1).focus();
        } else {
            $('#editForm button[type="submit"]').focus();
        }
    }

    // ===== Helper to move focus =====
    function moveToNextFieldAdd($current) {
        var $fields = $('#addForm').find('input, select, textarea').filter(':visible');
        var index = $fields.index($current);
        if (index + 1 < $fields.length) {
            $fields.eq(index + 1).focus();
        } else {
            $('#addForm button[type="submit"]').focus();
        }
        }

