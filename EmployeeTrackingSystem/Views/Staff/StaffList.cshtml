<script>
    function openEditPopup(btn) {

        let row = btn.closest("tr");

        let StaffCD = row.cells[0].innerText.trim();
        let StaffName = row.cells[1].innerText.trim();
        let SeatNo = row.cells[4].innerText.trim();

        // ✅ set values FIRST
        document.getElementById("StaffCD").value = StaffCD;
        document.getElementById("StaffName").value = StaffName;
        document.getElementById("SeatNo").value = SeatNo;

        // ✅ THEN show modal
        $('#editModal').modal('show');
    }
</script>
<script>
    $('#editForm').submit(function (e) {
        $.ajax({
            url: '/Staff/Update',
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {

                if (res.success) {
                    alert(res.message);
                    $('#editModal').modal('hide');
                    location.reload();
                } else {
                    alert("Error: " + res.message);
                }
            },
            error: function (err) {
                alert("Error: " + err.responseText);
            }
        });
    });
</script>

