<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - EmployeeTrackingSystem</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

</head>

<body>
    <style>
        .navbar-nav .nav-item .nav-link {
            text-decoration: none;
            font-weight: normal;
            color: white;
            padding: 15px 20px;
            transition: all 0.3s;
        }

            .navbar-nav .nav-item .nav-link.active {
                font-weight: bold;
                text-decoration: underline;
                color: #ffd800; /* optional highlight color */
            }
    </style>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <img src="@Url.Content("~/Content/Logo.png")" />
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav" id="menu">
                    <li class="nav-item"><a class="nav-link" href="/Home/Dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Staff/StaffList">Staff List</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Detail/DetailList">Detail List</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container body-content" style="margin-top:30px;">
        @if (ViewBag.ShowDropdown == true
        && ViewBag.Departments != null
         && ViewBag.StaffNames != null)
        {
            <div class="row">
                <div class="col-md-3">
                    <div class="col-md-12 form-group">
                        @Html.DropDownList("department", ViewBag.Departments as SelectList,
                                   new { @class = "form-control" ,id = "department" })
                        @if (ViewBag.Detail == "Detail")
                        {<br /><br /><input type="date" id="fromDate" class="form-control mt-2" placeholder="From Date" value="@ViewBag.FromDate">}
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="col-md-12 form-group">
                        @Html.DropDownList("staff", ViewBag.StaffNames as SelectList,
                                    new { @class = "form-control"  ,id = "staff" })
                        @if (ViewBag.Detail == "Detail")
                        {<br /><br /><input type="date" id="toDate" class="form-control mt-2" placeholder="To Date" value="@ViewBag.ToDate">}
                    </div>
                </div>
                <div class="col-md-4">
                    @RenderSection("Buttons", required: false)
                </div>
            </div>
        }
        @RenderBody()
       
        <footer></footer>
    </div>


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const menuLinks = document.querySelectorAll("#menu .nav-link");
            const currentPath = window.location.pathname.toLowerCase();

            menuLinks.forEach(link => {
                // Check if the link href matches current path
                if (link.getAttribute("href").toLowerCase() === currentPath) {
                    link.classList.add("active");
                }

                // Optional: set active on click (for SPA-like effect)
                link.addEventListener("click", function () {
                    menuLinks.forEach(l => l.classList.remove("active"));
                    this.classList.add("active");
                });
            });
        });
          $("#department").change(function () {
                var selectedDeptId = $(this).val();
                var $staffDropdown = $("#staff");

                // Clear the current options and show a placeholder
                $staffDropdown.empty();
                $staffDropdown.append('<option value="">Loading...</option>');

                if (selectedDeptId) {
                    $.ajax({
                        url: '@Url.Action("GetStaffByDepartment", "Detail")',
                        type: "GET",
                        data: { departmentId: selectedDeptId },
                        success: function (data) {
                            $staffDropdown.empty();
                            $staffDropdown.append('<option value="">All</option>');

                            // Loop through the JSON data and add options
                            $.each(data, function (index, item) {
                                $staffDropdown.append($('<option>', {
                                    value: item.Value,
                                    text: item.Text
                                }));
                            });
                        },
                        error: function () {
                            alert("Error loading staff members.");
                        }
                    });
                } else {
                    $staffDropdown.empty();
                    $staffDropdown.append('<option value="">All</option>');
                }
            });

    </script>
</body>
</html>
