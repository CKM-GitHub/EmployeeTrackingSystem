<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
   <style>
       .navbar-nav .nav-item .nav-link {
           text-decoration: none;
           font-weight: normal;
           color: white;
           padding: 15px 20px;
           transition: all 0.3s;
       }

           .navbar-nav .nav-item .nav-link.active {
               font-weight: bold;
               text-decoration: underline;
               color: #ffd800; /* optional highlight color */
           }
   </style>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <img src="@Url.Content("~/Content/Logo.png")" />
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav" id="menu">                   
                    <li class="nav-item"><a class="nav-link" href="/Home/Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/StaffList">StaffList</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/DetailList">DetailList</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    <script>document.addEventListener("DOMContentLoaded", function () {
        const menuLinks = document.querySelectorAll("#menu .nav-link");
        const currentPath = window.location.pathname.toLowerCase();

        menuLinks.forEach(link => {
            // Check if the link href matches current path
            if (link.getAttribute("href").toLowerCase() === currentPath) {
                link.classList.add("active");
            }

            // Optional: set active on click (for SPA-like effect)
            link.addEventListener("click", function() {
                menuLinks.forEach(l => l.classList.remove("active"));
                this.classList.add("active");
            });
        });
    });</script>
</body>
</html>
