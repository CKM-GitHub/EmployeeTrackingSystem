@model IEnumerable<EmployeeTrackingSystem.Models.DashboardViewModel>

@if (Model != null && Model.Any())
{
    var first = Model.First();
    int staffCount = 0;

    if (!string.IsNullOrEmpty(first.StaffName1)) { staffCount++; }
    if (!string.IsNullOrEmpty(first.StaffName2)) { staffCount++; }
    if (!string.IsNullOrEmpty(first.StaffName3)) { staffCount++; }
    if (!string.IsNullOrEmpty(first.StaffName4)) { staffCount++; }
    if (!string.IsNullOrEmpty(first.StaffName5)) { staffCount++; }

    <div class="table-responsive">
        <table class="board-table">
            <thead>
                <tr>
                    <th colspan="@staffCount">@first.DepartmentName</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model)
                {
                    string statusClass1 = "";
                    if (member.Status1 == "在席") { statusClass1 = "status-in"; }
                    else if (member.Status1 == "帰宅") { statusClass1 = "status-off"; }
                    else if (member.Status1 == "外出") { statusClass1 = "status-away"; }
                    else if (member.Status1 == "直行") { statusClass1 = "status-away"; }
                    else if (member.Status1 == "会議") { statusClass1 = "status-meeting"; }
                    else if (member.Status1 == "休み") { statusClass1 = "status-home"; }

                    string statusClass2 = "";
                    if (member.Status2 == "在席") { statusClass2 = "status-in"; }
                    else if (member.Status2 == "帰宅") { statusClass2 = "status-off"; }
                    else if (member.Status2 == "外出") { statusClass2 = "status-away"; }
                    else if (member.Status2 == "直行") { statusClass2 = "status-away"; }
                    else if (member.Status2 == "会議") { statusClass2 = "status-meeting"; }
                    else if (member.Status2 == "休み") { statusClass2 = "status-home"; }

                    string statusClass3 = "";
                    if (member.Status3 == "在席") { statusClass3 = "status-in"; }
                    else if (member.Status3 == "帰宅") { statusClass3 = "status-off"; }
                    else if (member.Status3 == "外出") { statusClass3 = "status-away"; }
                    else if (member.Status3 == "直行") { statusClass3 = "status-away"; }
                    else if (member.Status3 == "会議") { statusClass3 = "status-meeting"; }
                    else if (member.Status3 == "休み") { statusClass3 = "status-home"; }

                    string statusClass4 = "";
                    if (member.Status4 == "在席") { statusClass4 = "status-in"; }
                    else if (member.Status4 == "帰宅") { statusClass4 = "status-off"; }
                    else if (member.Status4 == "外出") { statusClass4 = "status-away"; }
                    else if (member.Status4 == "直行") { statusClass4 = "status-away"; }
                    else if (member.Status4 == "会議") { statusClass4 = "status-meeting"; }
                    else if (member.Status4 == "休み") { statusClass4 = "status-home"; }


                    string statusClass5 = "";
                    if (member.Status5 == "在席") { statusClass5 = "status-in"; }
                    else if (member.Status5 == "帰宅") { statusClass5 = "status-off"; }
                    else if (member.Status5 == "外出") { statusClass5 = "status-away"; }
                    else if (member.Status5 == "直行") { statusClass5 = "status-away"; }
                    else if (member.Status5 == "会議") { statusClass5 = "status-meeting"; }
                    else if (member.Status5 == "休み") { statusClass5 = "status-home"; }


                    <tr>
                        @if (!string.IsNullOrEmpty(member.StaffName1))
                        {
                            <td class="@statusClass1">
                                <table class="nested-table">
                                    <tr>
                                        <td colspan="2" class="nested-cell staffname">
                                            <a href="#"
                                               class="staff-link"
                                               data-toggle="modal"
                                               data-target="#staffModal"
                                               data-sid="@member.StaffCD1"
                                               data-did="@member.DepartmentCD"
                                               data-status="@member.Status1"
                                               data-returndatetime="@member.ReturnDatetime1"
                                               data-note="@member.Note1">
                                                @member.StaffName1
                                            </a>
                                            <img src="~/Content/search.png" class="search-icon" id="@member.StaffCD1"
                                                                         data-staffname="@member.StaffName1" />
                                        </td>
                                    </tr>
                                    <tr>
                                        @if (member.Status1 != "休み" && member.Status1 != "在席" && member.Status1 != "帰宅")
                                        {
                                            <td class="nested-top date">
                                                @{ string displayDate1 = "";
                                                    if (!string.IsNullOrEmpty(member.ReturnDatetime1))
                                                    {
                                                        DateTime dt;
                                                        if (DateTime.TryParse(member.ReturnDatetime1, out dt))
                                                        {
                                                            if (member.Status1 == "会議")
                                                            {
                                                                displayDate1 = dt.ToString("HH:mm:");
                                                            }
                                                            else if (member.Status1 == "外出" || member.Status1 == "直行")
                                                            {
                                                                displayDate1 = dt.ToString("yyyy-MM-dd HH:mm");
                                                            }
                                                        }
                                                    } }
                                                @displayDate1
                                            </td>

                                            <td class="nested-cell note">@(member.Note1 ?? "")</td>
                                        }
                                        else
                                        {
                                            <td colspan="2" class="nested-cell note">@(member.Note1 ?? "")</td>
                                        }
                                    </tr>
                                </table>
                            </td>
                        }
                        @if (!string.IsNullOrEmpty(member.StaffName2))
                        {
                            <td class="@statusClass2">
