                                               data-toggle="modal"
                                               data-target="#staffModal"
                                               data-sid="@member.StaffCD4"
                                               data-did="@member.DepartmentCD"
                                               data-status="@member.Status4"
                                               data-returndatetime="@member.ReturnDatetime4"
                                               data-note="@member.Note4">
                                                @member.StaffName4
                                            </a>
                                            <img src="~/Content/search.png" class="search-icon" id="@member.StaffCD4"
                                                                         data-staffname="@member.StaffName4" />
                                        </td>
                                    </tr>
                                    <tr>
                                        @if (member.Status4 != "休み" && member.Status4 != "在席" && member.Status4 != "帰宅")
                                        {
                                            <td class="nested-top date">
                                                @{ string displayDate4 = "";
                                                    if (!string.IsNullOrEmpty(member.ReturnDatetime4))
                                                    {
                                                        DateTime dt;
                                                        if (DateTime.TryParse(member.ReturnDatetime4, out dt))
                                                        {
                                                            if (member.Status4 == "会議")
                                                            {
                                                                displayDate4 = dt.ToString("HH:mm");
                                                            }
                                                            else if (member.Status4 == "外出" || member.Status4 == "直行")
