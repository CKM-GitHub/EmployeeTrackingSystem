                                            <td class="nested-cell note">@(member.Note3 ?? "")</td>
                                        }
                                        else
                                        {
                                            <td colspan="2" class="nested-cell note">@(member.Note3 ?? "")</td>
                                        }
                                    </tr>
                                </table>
                            </td>
                        }
                        @if (!string.IsNullOrEmpty(member.StaffName4))
                        {
                            <td class="@statusClass4">
                                <table class="nested-table">
                                    <tr>
                                        <td colspan="2" class="nested-cell staffname">
