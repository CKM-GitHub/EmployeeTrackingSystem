                                        {
                                            <td colspan="2" class="nested-cell note">@(member.Note4 ?? "")</td>
                                        }
                                    </tr>
                                </table>
                            </td>
                        }
                        @if (!string.IsNullOrEmpty(member.StaffName5))
                        {
                            <td class="@statusClass5">
                                <table class="nested-table">
                                    <tr>
                                        <td colspan="2" class="nested-cell staffname">
                                            <a href="#"
                                               class="staff-link"
