                                                                         data-staffname="@member.StaffName2" />
                                        </td>
                                    </tr>
                                    <tr>
                                        @if (member.Status2 != "休み" && member.Status2 != "在席" && member.Status2 != "帰宅")
                                        {
                                            <td class="nested-top date">
                                                @{ string displayDate2 = "";
                                                    if (!string.IsNullOrEmpty(member.ReturnDatetime2))
                                                    {
                                                        DateTime dt;
                                                        if (DateTime.TryParse(member.ReturnDatetime2, out dt))
                                                        {
                                                            if (member.Status2 == "会議")
                                                            {
                                                                displayDate2 = dt.ToString("HH:mm");
                                                            }
                                                            else if (member.Status2 == "外出" || member.Status2 == "直行")
                                                            {
                                                                displayDate2 = dt.ToString("yyyy-MM-dd HH:mm");
                                                            }
                                                        }
                                                    } }
                                                @displayDate2
                                            </td>
                                            <td class="nested-cell note">@(member.Note2 ?? "")</td>
                                        }
                                        else
                                        {
                                            <td colspan="2" class="nested-cell note">@(member.Note2 ?? "")</td>
                                        }
                                    </tr>
                                </table>
                            </td>
                        }
                        @if (!string.IsNullOrEmpty(member.StaffName3))
                        {
                            <td class="@statusClass3">
                                <table class="nested-table">
                                    <tr>
                                        <td colspan="2" class="nested-cell staffname">
                                            <a href="#"
                                               class="staff-link"
