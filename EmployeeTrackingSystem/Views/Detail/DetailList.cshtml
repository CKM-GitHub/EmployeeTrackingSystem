
@{
    ViewBag.Title = "DetailList";
}
@model IEnumerable<EmployeeTrackingSystem.Models.DetailViewModel>


@section Buttons {
    <button class="btn btn-warning" style="width:100px; font-weight:bold;" onclick="searchData()">検索</button>
    <button class="btn btn-primary" style="width:100px; font-weight:bold;" onclick="exportExcel()">Excel</button>
}


<table id="detailtb" class="table table-striped table-bordered" style="width:100%">
    <thead>
        <tr class="table-header" style="background-color: #BDD7EE;">
            <th>Staff Name</th>
            <th>Department</th>
            <th style="text-align:center">Status</th>
            <th>StartDateTime</th>
            <th>ReturnDateTime</th>
            <th>Remark</th>
        </tr>
    </thead>
    <tbody id="DetailTable">
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StaffName</td>
                <td>@item.DepartmentName</td>
                <td style="background-color:@GetStatusColor(item.Status)" align="center">@item.Status</td>
                <td>@item.StartDateTime</td>
                <td>@item.ReturnDateTime</td>
                <td>@item.Note</td>
            </tr>
        }
    </tbody>
</table>

@functions {
    public string GetStatusColor(string status)
    {
        switch (status)
        {
            case "直行": return "#E6CF25";
            case "外出": return "#E6CF25";
            case "休み": return "#FF0011";
            case "帰宅": return "#545956";
            case "在席": return "#1FA148";
            case "会議": return "#BA56CC";
            default: return "";
        }
    }
}

@section Scripts {
  

    <script type="text/javascript">

        $(document).ready(function () {
            $('#department').select2();
            $('#staff').select2();
        });

        function searchData() {

        var searchParams = {
            departMent: $('#department').val(),
            staffName: $('#staff').val(),
            fromDate: $('#fromDate').val(),
            toDate: $('#toDate').val()
            };

            $.ajax({
            url: '@Url.Action("GetFilteredData", "Detail")',
            type: 'POST',
                data: searchParams,
                success: function (data) {
                    var items = "";
                    $('#DetailTable').empty(); // Clear current table rows

                    // 3. Loop through JSON result
                    $.each(data, function (i, item) {
                        items += "<tr>" +
                            "<td>" + (item.StaffName || "") + "</td>" +
                            "<td>" + (item.DepartmentName || "") + "</td>" +
                            "<td style=background-color:" + getStatusColor(item.Status) + " align = center>" + (item.Status || "") + "</td>" +
                            "<td>" + (item.StartDateTime || "") + "</td>" +
                            "<td>" + (item.ReturnDateTime || "") + "</td>" +
                            "<td>" + (item.Note || "") + "</td>" +
                            "</tr>";
                    });

                    // 4. Bind to table
                    $('#DetailTable').html(items);

            }
        });
    }

        function getStatusColor(status) {
            if (status == "直行") return "#E6CF25";
            if (status == "外出") return "#E6CF25";
            if (status == "休み") return "#FF0011";
            if (status == "帰宅") return "#545956";
            if (status == "在席") return "#1FA148";
            if (status == "会議") return "#BA56CC";
        return "";
    }

    function exportExcel() {
        // Redirect to your Controller action that generates a FileResult (Excel)
        window.location.href = '@Url.Action("ExportToExcel", "Detail")' +
                               '?dept=' + $('#ddlDepartment').val();
    }
    </script>
}

