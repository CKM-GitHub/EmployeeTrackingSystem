@using EmployeeTrackingSystem.Models
@{
    ViewBag.Title = "DetailList";
}
@model IEnumerable<EmployeeTrackingSystem.Models.DetailViewModel>

<div class="container-fluid mt-3">
    @section Buttons {
        <button class="btn_search btn" id="btn_search">検索</button>
        <button class="btn_Blue btn btn-primary" id="btn_Excel">Excel</button>
    }

    <div class="table-v-scroll table-responsive">
        <table id="detailtb" class="table table-striped table-hover">
            <thead>
                <tr class="table-header">
                    <th width="10%">スタッフ名</th>
                    <th width="15%">部門名</th>
                    <th class="th_center" width="5%">状態</th>
                    <th class="th_center" width="15%">開始日時</th>
                    <th class="th_center" width="15%">
                        終了日時
                    </th>
                    <th width="40%">備考</th>
                </tr>
            </thead>
            <tbody id="DetailTable">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="truncate-logic">@item.StaffName</td>
                        <td>@item.DepartmentName</td>
                        <td class="th_center" style="background-color:@GetStatusColor(item.Status)">@item.Status</td>
                        <td class="th_center">@(item.StartDateTime.HasValue ? item.StartDateTime.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                        <td class="th_center">@(item.ReturnDateTime.HasValue ? item.ReturnDateTime.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                        <td>
                            <div class="truncate-logic">
                                @item.Note
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    public string GetStatusColor(string status)
    {
        switch (status)
        {
            case "直行": return "#e3dca8";
            case "外出": return "#e3dca8";
            case "休み": return "#eb888f";
            case "帰宅": return "#848786";
            case "在席": return "#c7f0d4";
            case "会議": return "#f0a3dd";
            default: return "";
        }
    }
}

@section Scripts {
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <script>

        $(document).ready(function () {
            $('#department').select2();
            $('#staff').select2();

            $(document).on("click", "#btn_search", function () {
                var searchParams = {
                departMent: $('#department').val(),
                staffName: $('#staff').val(),
                fromDate: $('#fromDate').val(),
                toDate: $('#toDate').val()
                };
                $.ajax({
                url: '@Url.Action("GetFilteredData", "Detail")',
                type: 'POST',
                data: searchParams,
                success: function (data) {
                    var items = "";
                    $('#DetailTable').empty(); // Clear current table rows

                    // 3. Loop through JSON result
                    $.each(data, function (i, item) {
                        items += "<tr>" +
                            "<td class='truncate-logic'>" + (item.StaffName || "") + "</td>" +
                            "<td>" + (item.DepartmentName || "") + "</td>" +
                            "<td style=background-color:" + getStatusColor(item.Status) + " align = center>" + (item.Status || "") + "</td>" +
                            "<td class='th_center'>" + (item.StartDateTime || "") + "</td>" +
                            "<td class='th_center'>" + (item.ReturnDateTime || "") + "</td>" +
                            "<td class='truncate-logic'>" + (item.Note || "") + "</td>" +
                            "</tr>";
                    });
                    // 4. Bind to table
                    $('#DetailTable').html(items);
                }
                });
            });

              //Excel Export
            $(document).on("click", "#btn_Excel", function () {
                // Collect all your filter values
                var filters = {
                    departMent: $('#department').val(),
                    staffName: $('#staff').val(),
                    fromDate: $('#fromDate').val(),
                    toDate: $('#toDate').val()
                };
                // Create a hidden form dynamically
                var $form = $('<form>', {
                    action: '@Url.Action("ExportToExcel", "Detail")',
                    method: 'post',
                    data: filters
                });
                // Add each filter as a hidden input
                $.each(filters, function (key, value) {
                $form.append($('<input>', {
                    type: 'hidden',
                    name: key,
                    value: value
                }));
                });
                // Append to body, submit, and remove
                $(document.body).append($form);
                $form.submit();
                $form.remove();
            });

            document.addEventListener("mouseover", function (e) {
                // Check if the hovered element has our class
                if (e.target.classList.contains("truncate-logic")) {
                    const el = e.target;

                    // If the actual text width is wider than the container
                    if (el.scrollWidth > el.clientWidth) {
                        // Set the title only for long strings
                        el.setAttribute("title", el.innerText);
                        el.style.cursor = "pointer";
                    } else {
                        // Remove title if it's a short string
                        el.removeAttribute("title");
                        el.style.cursor = "default";
                    }
                }
            });
        });

        function getStatusColor(status) {
            if (status == "直行") return "#e3dca8";
            if (status == "外出") return "#e3dca8";
            if (status == "休み") return "#eb888f";
            if (status == "帰宅") return "#848786";
            if (status == "在席") return "#c7f0d4";
            if (status == "会議") return "#f0a3dd";
        return "";
    }

    </script>
}

